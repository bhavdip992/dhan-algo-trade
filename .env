# ════════════════════════════════════════════════════════════════════
#  TRADE MODE
#  true  = Paper trade (simulate, no real orders)
#  false = LIVE trade  (real money — double check before setting)
#
#  NOTE: Dhan requires static IP whitelisted for order APIs.
#        Whitelist your EC2 elastic IP at:
#        Dhan Web → Profile → DhanHQ APIs → IP Whitelist
# ════════════════════════════════════════════════════════════════════
PAPER_TRADE=false

# ════════════════════════════════════════════════════════════════════
#  INDEX
#   NIFTY      → LOT_SIZE=65  STRIKE_STEP=50   EXPIRY_WEEKDAY=TUE
#   BANKNIFTY  → LOT_SIZE=30  STRIKE_STEP=100  EXPIRY_WEEKDAY=WED
#   FINNIFTY   → LOT_SIZE=65  STRIKE_STEP=50   EXPIRY_WEEKDAY=THU
#   MIDCPNIFTY → LOT_SIZE=120 STRIKE_STEP=25   EXPIRY_WEEKDAY=THU
# ════════════════════════════════════════════════════════════════════
INDEX=NIFTY
LOT_SIZE=65
STRIKE_STEP=50
EXPIRY_WEEKDAY=TUE

# ── Option settings ──────────────────────────────────────────────────
EXPIRY_TYPE=Weekly          # Weekly | Monthly
STRIKE_MODE=OTM1             # ATM | OTM1 | OTM2 | ITM1 | ITM2
OPTION_TYPE=AUTO            # AUTO | CE Only | PE Only

# ── Candle timeframe ─────────────────────────────────────────────────
TIMEFRAME=5                 # 1 | 5 | 15 (minutes)

# ════════════════════════════════════════════════════════════════════
#  CAPITAL & RISK
# ════════════════════════════════════════════════════════════════════
MAX_CAPITAL=33000
MAX_DAILY_LOSS=3            # Halt when loss > 3% = ₹3000
MAX_TRADES=3                # Max trades per day
MAX_PREMIUM=450             # Max option premium/share to buy
RISK_PCT=2.0                # Risk per trade = 2% of capital
MAX_LOTS=1                  # Hard cap on lots per trade

# ════════════════════════════════════════════════════════════════════
#  SIGNAL ENGINE  (same as before — unchanged)
# ════════════════════════════════════════════════════════════════════
EMA_FAST=9
EMA_MID=21
EMA_SLOW=50
EMA_TREND=200

ST_ATR_LEN=10
ST_FACTOR=2.5

RSI_LEN=14
RSI_OB=65
RSI_OS=32

ADX_THRESH=22
VOL_MULT=1.2
VOL_REQUIRED=false

BB_LEN=20
BB_STD=2.0

MIN_CONFIRMATIONS=5

SL_MODE=ATR
SL_ATR_MULT=1.2
SL_PCT=0.5

TGT_MODE=ATR
TGT_PCT=1.5
TGT_ATR_MULT=2.5

USE_TRAIL=true
TRAIL_TRIG=0.8
TRAIL_STEP=0.4

# ════════════════════════════════════════════════════════════════════
#  TELEGRAM BOT
#  Get token from @BotFather → /newbot
#  Get chat_id: message your bot, then visit:
#  https://api.telegram.org/bot<TOKEN>/getUpdates
